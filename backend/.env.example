# Email — sent via Brevo's HTTPS Transactional Email API (NOT SMTP).
# Render/Heroku-style hosts block outbound SMTP ports (587/465/25), so SMTP
# relays time out in production. The HTTP API uses port 443 and always works.
# Get this key from Brevo: Settings -> SMTP & API -> API Keys tab -> Generate a new API key
# (this is DIFFERENT from the SMTP key — it usually starts with "xkeysib-")
BREVO_API_KEY=your_brevo_api_key
FROM_EMAIL=noreply@spiritual-revamp.in
FROM_NAME=spiritual-revamp
CONTACT_EMAIL=you@example.com

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174
